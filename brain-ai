#!/bin/bash
set -e
cd "$(dirname "$0")"

PID_FILE="/tmp/brain-rag.pid"
APP_NAME="Brain RAG"
PORT=8000
VENV="venv/bin/activate"

# Colors
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log() { echo -e "${GREEN}[Brain RAG]${NC} $1"; }
warn() { echo -e "${YELLOW}[Brain RAG]${NC} $1"; }
err()  { echo -e "${RED}[Brain RAG]${NC} $1"; }

start() {
    if is_running; then
        warn "Already running (PID: $(cat $PID_FILE))"
        return
    fi

    # Check venv
    if [ ! -f "$VENV" ]; then
        err "Virtual environment not found. Run: python3 -m venv venv && source venv/bin/activate && pip install -r requirements.txt"
        exit 1
    fi

    # Check models
    local models_missing=0
    for model in ~/models/Qwen3-Embedding-0.6B-f16.gguf \
                 ~/models/Qwen3.5-2B.Q4_K_M.gguf \
                 ~/models/Llama-3.2-1B-Instruct-Q4_K_M.gguf \
                 ~/models/gemma-3-4b-it-Q4_K_M.gguf; do
        if [ ! -f "$model" ]; then
            warn "Missing model: $model"
            models_missing=1
        fi
    done
    if [ $models_missing -eq 1 ]; then
        warn "Some models are missing - service may fail on first query"
    fi

    log "Starting $APP_NAME..."
    source "$VENV"
    nohup python -m uvicorn app.main:app --host 127.0.0.1 --port $PORT > /tmp/brain-rag.log 2>&1 &
    echo $! > "$PID_FILE"

    # Wait for startup
    log "Waiting for server..."
    for i in $(seq 1 15); do
        if curl -s http://127.0.0.1:$PORT/health > /dev/null 2>&1; then
            log "$APP_NAME ready at http://127.0.0.1:$PORT"
            log "API docs: http://127.0.0.1:$PORT/docs"
            return
        fi
        sleep 1
    done

    warn "Server didn't respond in 15s. Check logs: tail -f /tmp/brain-rag.log"
}

stop() {
    if ! is_running; then
        warn "Not running"
        rm -f "$PID_FILE"
        return
    fi

    local PID=$(cat "$PID_FILE")
    log "Stopping $APP_NAME (PID: $PID)..."
    kill "$PID" 2>/dev/null

    # Wait for graceful shutdown
    for i in $(seq 1 5); do
        if ! kill -0 "$PID" 2>/dev/null; then
            break
        fi
        sleep 1
    done

    # Force kill if still running
    if kill -0 "$PID" 2>/dev/null; then
        log "Force killing..."
        kill -9 "$PID" 2>/dev/null
    fi

    rm -f "$PID_FILE"
    log "Stopped"
}

restart() {
    stop
    sleep 1
    start
}

status() {
    if is_running; then
        local PID=$(cat "$PID_FILE")
        log "Running (PID: $PID)"
        log "URL: http://127.0.0.1:$PORT"
        log "Docs: http://127.0.0.1:$PORT/docs"
    else
        warn "Not running"
        rm -f "$PID_FILE"
    fi
}

logs() {
    if [ -f /tmp/brain-rag.log ]; then
        tail -f /tmp/brain-rag.log
    else
        warn "No log file found"
    fi
}

ingest() {
    log "Starting ingestion..."
    curl -s -X POST http://127.0.0.1:$PORT/ingest | python3 -m json.tool
    echo
}

is_running() {
    if [ -f "$PID_FILE" ]; then
        local PID=$(cat "$PID_FILE")
        if kill -0 "$PID" 2>/dev/null; then
            return 0
        fi
    fi
    return 1
}

case "$1" in
    start)   start ;;
    stop)    stop ;;
    restart) restart ;;
    status)  status ;;
    logs)    logs ;;
    ingest)  ingest ;;
    *)
        echo -e "${BLUE}Brain RAG - Second Brain Local${NC}"
        echo ""
        echo "Usage: ./brain-ai {start|stop|restart|status|logs|ingest}"
        echo ""
        echo "Commands:"
        echo "  start    - Start the RAG service"
        echo "  stop     - Stop the RAG service"
        echo "  restart  - Restart the service"
        echo "  status   - Check if running"
        echo "  logs     - Follow service logs"
        echo "  ingest   - Reindex all documents"
        ;;
esac
